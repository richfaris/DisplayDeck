<UserControl x:Class="DisplayDeck.App.Views.DisplaysView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:DisplayDeck.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:MainViewModel}"
             d:DesignHeight="760" d:DesignWidth="900">

    <Grid>
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,8,28,90">
            <StackPanel>

                <!-- Header -->
                <Grid Margin="0,8,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Displays" FontSize="30" FontWeight="Bold" />
                        <TextBlock Text="{Binding SummaryText}" Opacity="0.7" FontSize="14" Margin="0,2,0,0" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" VerticalAlignment="Center"
                               Icon="{ui:SymbolIcon ArrowSync24}"
                               Content="Refresh" Command="{Binding RefreshCommand}" />
                </Grid>

                <!-- Arrangement map -->
                <Border CornerRadius="12" Margin="0,0,0,20"
                        Background="{DynamicResource ControlFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                    <StackPanel Margin="20,16,20,20">
                        <TextBlock Text="ARRANGEMENT" FontSize="11" FontWeight="SemiBold"
                                   Opacity="0.55" Margin="2,0,0,12" />
                        <Border CornerRadius="10" ClipToBounds="True"
                                Background="{DynamicResource ControlFillColorSecondaryBrush}"
                                Width="{Binding MapCanvasWidth}" Height="{Binding MapCanvasHeight}"
                                HorizontalAlignment="Center">
                            <ItemsControl ItemsSource="{Binding Displays}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <Canvas />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Canvas.Left" Value="{Binding MapLeft}" />
                                        <Setter Property="Canvas.Top" Value="{Binding MapTop}" />
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DisplayItemViewModel}">
                                        <Border Width="{Binding MapWidth}" Height="{Binding MapHeight}"
                                                CornerRadius="8" Margin="3" BorderThickness="1.5"
                                                BorderBrush="{DynamicResource SystemAccentColorSecondaryBrush}">
                                            <Border.Background>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                    <GradientStop Color="#2F6BFF" Offset="0" />
                                                    <GradientStop Color="#8A4BFF" Offset="1" />
                                                </LinearGradientBrush>
                                            </Border.Background>
                                            <Grid>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding ShortName}" Foreground="White"
                                                               FontWeight="Bold" FontSize="15" HorizontalAlignment="Center" />
                                                    <TextBlock Text="{Binding ResolutionText}" Foreground="#DDFFFFFF"
                                                               FontSize="11" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                                </StackPanel>
                                                <ui:SymbolIcon Symbol="Star24" Filled="True" Foreground="Gold"
                                                               FontSize="16" Margin="6"
                                                               HorizontalAlignment="Left" VerticalAlignment="Top"
                                                               Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibility}}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Detail + control cards -->
                <ItemsControl ItemsSource="{Binding Displays}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:DisplayItemViewModel}">
                            <Border Width="360" Margin="0,0,16,16" CornerRadius="12"
                                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                    BorderThickness="1">
                                <StackPanel Margin="18,16,18,18">
                                    <Grid>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Label}" FontSize="17" FontWeight="SemiBold"
                                                       TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{Binding ShortName}" Opacity="0.6" FontSize="12" />
                                        </StackPanel>
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                CornerRadius="6" Padding="8,3"
                                                Background="{DynamicResource SystemAccentColorSecondaryBrush}"
                                                Visibility="{Binding IsPrimary, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="PRIMARY" Foreground="White" FontSize="10" FontWeight="Bold" />
                                        </Border>
                                    </Grid>

                                    <Border Height="1" Margin="0,14"
                                            Background="{DynamicResource CardStrokeColorDefaultBrush}" />

                                    <!-- Quick controls -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="10" />
                                            <ColumnDefinition Width="130" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Resolution" Opacity="0.6" Margin="2,0,0,4" FontSize="12" />
                                            <ComboBox ItemsSource="{Binding ResolutionOptions}"
                                                      SelectedItem="{Binding SelectedResolution}"
                                                      HorizontalAlignment="Stretch" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="Refresh" Opacity="0.6" Margin="2,0,0,4" FontSize="12" />
                                            <ComboBox ItemsSource="{Binding RefreshOptions}"
                                                      SelectedItem="{Binding SelectedRefresh}"
                                                      HorizontalAlignment="Stretch">
                                                <ComboBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding StringFormat='{}{0} Hz'}" />
                                                    </DataTemplate>
                                                </ComboBox.ItemTemplate>
                                            </ComboBox>
                                        </StackPanel>
                                    </Grid>

                                    <TextBlock Margin="2,8,0,0" Opacity="0.5" FontSize="11"
                                               Text="Changes apply instantly — you'll get 15s to confirm." />

                                    <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                        <ui:Button Content="Rotate 90°"
                                                   Icon="{ui:SymbolIcon ArrowRotateClockwise24}"
                                                   Command="{Binding RotateCommand}" />
                                        <ui:Button Margin="8,0,0,0" Content="Make primary"
                                                   Icon="{ui:SymbolIcon Star24}"
                                                   Command="{Binding MakePrimaryCommand}"
                                                   Visibility="{Binding CanMakePrimary, Converter={StaticResource BoolToVisibility}}" />
                                    </StackPanel>

                                    <TextBlock Margin="2,14,0,0" Opacity="0.55" FontSize="12">
                                        <Run Text="{Binding Orientation, Converter={StaticResource OrientationToLabel}, Mode=OneWay}" />
                                        <Run Text="·" />
                                        <Run Text="{Binding ColorDepthText, Mode=OneWay}" />
                                        <Run Text="· position" />
                                        <Run Text="{Binding PositionText, Mode=OneWay}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
