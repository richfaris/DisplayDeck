<UserControl x:Class="DisplayDeck.App.Views.ProfilesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:DisplayDeck.App.ViewModels"
             mc:Ignorable="d"
             d:DataContext="{d:DesignInstance vm:ProfilesViewModel}"
             d:DesignHeight="760" d:DesignWidth="900">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,8,28,40">
        <StackPanel>

            <!-- Header -->
            <StackPanel Margin="0,8,0,16">
                <TextBlock Text="Profiles" FontSize="30" FontWeight="Bold" />
                <TextBlock Text="Save your current display setup and switch back to it in one click."
                           Opacity="0.7" FontSize="14" Margin="0,2,0,0" />
            </StackPanel>

            <!-- Save current setup -->
            <Border CornerRadius="12" Margin="0,0,0,20" Padding="20,18"
                    Background="{DynamicResource ControlFillColorDefaultBrush}"
                    BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                        <TextBlock Text="SAVE CURRENT SETUP" FontSize="11" FontWeight="SemiBold"
                                   Opacity="0.55" Margin="0,0,0,8" />
                        <ui:TextBox PlaceholderText="Name this setup (e.g. Work, Gaming, Movie)…"
                                    Text="{Binding NewProfileName, UpdateSourceTrigger=PropertyChanged}"
                                    Icon="{ui:SymbolIcon Save24}" />
                    </StackPanel>
                    <ui:Button Grid.Column="1" VerticalAlignment="Bottom" Appearance="Primary"
                               Icon="{ui:SymbolIcon SaveCopy24}" Content="Save current setup"
                               Command="{Binding SaveCurrentCommand}" />
                </Grid>
            </Border>

            <!-- Empty state -->
            <Border CornerRadius="12" Padding="40" Margin="0,0,0,8"
                    Background="{DynamicResource ControlFillColorSecondaryBrush}"
                    Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center">
                    <ui:SymbolIcon Symbol="Save24" FontSize="40" Opacity="0.4" HorizontalAlignment="Center" />
                    <TextBlock Text="No profiles yet" FontSize="16" FontWeight="SemiBold"
                               HorizontalAlignment="Center" Margin="0,12,0,2" />
                    <TextBlock Text="Arrange your displays how you like, then save this setup above."
                               Opacity="0.6" HorizontalAlignment="Center" TextAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Saved profiles -->
            <ItemsControl ItemsSource="{Binding Profiles}"
                          Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}, ConverterParameter=invert}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:ProfileItemViewModel}">
                        <Border Margin="0,0,0,12" CornerRadius="12" Padding="18,16"
                                Background="{DynamicResource ControlFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                                    <ui:TextBox Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                                FontSize="16" FontWeight="SemiBold"
                                                BorderThickness="0" Background="Transparent"
                                                Padding="0" ToolTip="Click to rename" />
                                    <TextBlock Text="{Binding Summary}" Opacity="0.75" FontSize="13" Margin="2,4,0,0" />
                                    <TextBlock Text="{Binding CreatedText}" Opacity="0.45" FontSize="11" Margin="2,2,0,0" />
                                </StackPanel>

                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                    <ui:Button Appearance="Primary" Content="Apply"
                                               Icon="{ui:SymbolIcon Checkmark24}"
                                               Command="{Binding ApplyCommand}" />
                                    <ui:Button Margin="8,0,0,0" ToolTip="Delete profile"
                                               Icon="{ui:SymbolIcon Delete24}"
                                               Command="{Binding DeleteCommand}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>
</UserControl>
