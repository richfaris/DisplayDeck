<UserControl x:Class="DisplayDeck.App.Views.AboutView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
             xmlns:vm="clr-namespace:DisplayDeck.App.ViewModels"
             mc:Ignorable="d" d:DesignHeight="760" d:DesignWidth="900">

    <UserControl.Resources>
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Margin" Value="0,0,0,16" />
            <Setter Property="Padding" Value="22,18" />
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Opacity" Value="0.6" />
            <Setter Property="Margin" Value="0,0,0,3" />
        </Style>
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,14" />
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,8,28,24">
        <StackPanel MaxWidth="820" HorizontalAlignment="Left">

            <TextBlock Text="Source &amp; Builder" FontSize="30" FontWeight="Bold" Margin="0,8,0,4" />
            <TextBlock Text="Where this app lives and what built it — so you can always find and improve it later."
                       Opacity="0.7" FontSize="14" TextWrapping="Wrap" Margin="0,0,0,20" />

            <!-- Moved notice -->
            <Border Style="{StaticResource Card}" Background="#3A2E00" BorderBrush="#8A6D00"
                    Visibility="{Binding LocationChanged, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <ui:SymbolIcon Symbol="Info24" VerticalAlignment="Center" />
                    <TextBlock Margin="12,0,0,0" VerticalAlignment="Center" TextWrapping="Wrap"
                               Text="This app was launched from a new location — the paths below have been updated." />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="BUILDER" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding Builder}" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="GITHUB REPOSITORY" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding RepositoryUrl}"
                               FontFamily="Cascadia Mono, Consolas" />
                    <ui:Button Content="Open on GitHub" Icon="{ui:SymbolIcon Open24}"
                               Command="{Binding OpenRepositoryCommand}" IsEnabled="{Binding HasRepository}"
                               HorizontalAlignment="Left" Margin="0,0,0,14" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="AI ASSISTANT" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding AIAssistant}" Margin="0" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="SOURCE FILES LOCATION" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding SourceRoot}"
                               FontFamily="Cascadia Mono, Consolas" />

                    <TextBlock Style="{StaticResource FieldLabel}" Text="SOLUTION FILE" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding SolutionPath}"
                               FontFamily="Cascadia Mono, Consolas" />

                    <StackPanel Orientation="Horizontal">
                        <ui:Button Content="Open source folder" Icon="{ui:SymbolIcon FolderOpen24}"
                                   Command="{Binding OpenSourceCommand}" IsEnabled="{Binding HasSource}" />
                        <ui:Button Margin="8,0,0,0" Content="Open in Cursor" Appearance="Primary"
                                   Icon="{ui:SymbolIcon Code24}"
                                   Command="{Binding OpenInCursorCommand}" IsEnabled="{Binding HasSource}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock Style="{StaticResource FieldLabel}" Text="CURRENTLY RUNNING FROM" />
                    <TextBlock Style="{StaticResource FieldValue}" Text="{Binding RunLocation}"
                               FontFamily="Cascadia Mono, Consolas" />
                    <ui:Button Content="Open this folder" Icon="{ui:SymbolIcon FolderOpen24}"
                               Command="{Binding OpenRunLocationCommand}" HorizontalAlignment="Left" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource Card}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="FIRST SEEN" />
                        <TextBlock Style="{StaticResource FieldValue}" Text="{Binding FirstSeen}" Margin="0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Style="{StaticResource FieldLabel}" Text="PATHS LAST UPDATED" />
                        <TextBlock Style="{StaticResource FieldValue}" Text="{Binding LastUpdated}" Margin="0" />
                    </StackPanel>
                </Grid>
            </Border>

            <TextBlock Opacity="0.5" FontSize="12" TextWrapping="Wrap"
                       Text="Tip: 'Open in Cursor' needs the Cursor command-line tool installed (Cursor → Command Palette → 'Install cursor command'). Otherwise it opens the folder." />

        </StackPanel>
    </ScrollViewer>
</UserControl>
